<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import com.jfoenix.controls.JFXTextField?>
<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="428.0" prefWidth="721.0" xmlns="http://javafx.com/javafx/8.0.111" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.ClientController">
  <children>
    <MenuBar fx:id="bar" prefHeight="28.0" prefWidth="640.0" stylesheets="@BasicApplication.css" VBox.vgrow="NEVER">
      <menus>
            <Menu mnemonicParsing="false" text="Control">
              <items>
                <MenuItem mnemonicParsing="false" text="Quit" />
                  <SeparatorMenuItem mnemonicParsing="false" />
                  <Menu mnemonicParsing="false" text="Help Center">
                    <items>
                      <MenuItem mnemonicParsing="false" text="D.M me">
                           <graphic>
                              <Hyperlink text="Hyperlink" />
                           </graphic>
                        </MenuItem>
                    </items>
                  </Menu>
              </items>
            </Menu>
      </menus>
         <effect>
            <InnerShadow />
         </effect>
    </MenuBar>
    <AnchorPane maxHeight="-1.0" maxWidth="-1.0" prefHeight="376.0" prefWidth="640.0" stylesheets="@BasicApplication.css" VBox.vgrow="ALWAYS">
      <children>
            <Label layoutX="14.0" layoutY="14.0" text="Host IP:" />
            <TextField fx:id="txtHostIP" layoutX="61.0" layoutY="10.0" text="localhost" />
            <Label layoutX="222.0" layoutY="14.0" text="Username:" />
            <TextField fx:id="txtUsername" layoutX="286.0" layoutY="10.0">
               <font>
                  <Font name="SansSerif Regular" size="12.0" />
               </font>
            </TextField>
            <TextArea fx:id="txtAreaServerMsgs" editable="false" layoutX="14.0" layoutY="43.0" prefHeight="193.0" prefWidth="421.0" wrapText="true" />
            <TitledPane layoutX="450.0" layoutY="40.0" prefHeight="207.0" prefWidth="252.0" text="Users">
              <content>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="172.0">
                     <children>
                        <ListView fx:id="listUser" layoutX="5.0" prefHeight="176.0" prefWidth="245.0" />
                     </children>
                  </AnchorPane>
              </content>
            </TitledPane>
            <Button fx:id="btnSend" layoutX="453.0" layoutY="313.0" mnemonicParsing="false" onAction="#sendMessage" onKeyPressed="#sendMessage" prefHeight="44.0" prefWidth="252.0" styleClass="root" stylesheets="@application.css" text="Send &gt;&gt;" />
            <TextArea fx:id="txtUserMsg" layoutX="14.0" layoutY="251.0" onKeyPressed="#handleEnterPressed" prefHeight="114.0" prefWidth="421.0" promptText="Type your Message here..." wrapText="true" />
            <Label fx:id="tradeLabel" layoutX="14.0" layoutY="378.0" text="nChat v1.0" textFill="#1cc70a">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <JFXTextField fx:id="serverPort" layoutX="568.0" layoutY="265.0" prefHeight="25.0" prefWidth="60.0">
               <tooltip>
                  <Tooltip text="Press Port After copying the Server Port Number" />
               </tooltip>
            </JFXTextField>
            <Label layoutX="448.0" layoutY="269.0" text="Dedicated Port(Server)" />
            <JFXButton buttonType="RAISED" layoutX="637.0" layoutY="265.0" onAction="#submitPort" prefHeight="25.0" prefWidth="68.0" ripplerFill="RED" text="Port" />
            <JFXButton fx:id="btnLogout" layoutX="608.0" layoutY="9.0" onAction="#logout" prefHeight="28.0" prefWidth="90.0" text="LOG OUT" textFill="RED" />
            <JFXButton fx:id="btnLogin" layoutX="450.0" layoutY="6.0" onAction="#login" prefHeight="28.0" prefWidth="97.0" text="LOG IN" textFill="GREEN" />
            <JFXButton layoutX="637.0" layoutY="364.0" onAction="#exit" prefHeight="28.0" prefWidth="68.0" styleClass="offButton" stylesheets="@application.css" text="BACK" textFill="WHITE">
               <font>
                  <Font name="Arial Bold" size="12.0" />
               </font>
            </JFXButton>
      </children>
         <styleClass>
            <String fx:value="menu" />
            <String fx:value="menu" />
         </styleClass>
    </AnchorPane>
  </children>
  <stylesheets>
    <URL value="@css/BasicApplication.css" />
  </stylesheets>
</VBox>
