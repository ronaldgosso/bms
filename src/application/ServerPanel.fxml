<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import com.jfoenix.controls.JFXTextField?>
<?import java.net.URL?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="503.0" prefWidth="745.0" xmlns="http://javafx.com/javafx/8.0.111" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.ServerController">
  <children>
    <MenuBar prefHeight="42.0" prefWidth="640.0" stylesheets="@BasicApplication.css" VBox.vgrow="NEVER">
      <menus>
        <Menu mnemonicParsing="false" text="File">
          <items>
            <MenuItem mnemonicParsing="false" text="Open…" />
            <MenuItem mnemonicParsing="false" text="Close" />
          </items>
        </Menu>
        <Menu mnemonicParsing="false" text="Help">
          <items>
            <MenuItem mnemonicParsing="false" text="nChat" />
          </items>
        </Menu>
      </menus>
    </MenuBar>
    <AnchorPane maxHeight="-1.0" maxWidth="-1.0" prefHeight="385.0" prefWidth="676.0" VBox.vgrow="ALWAYS">
      <children>
            <TextArea fx:id="txtAreaChatMsg" editable="false" layoutX="14.0" layoutY="90.0" prefHeight="190.0" prefWidth="334.0" wrapText="true" />
            <Label layoutX="664.0" layoutY="11.0" prefHeight="25.0" prefWidth="67.0" text="Server Panel" textFill="RED">
               <font>
                  <Font name="Arial Narrow" size="14.0" />
               </font></Label>
            <TextArea fx:id="txtAreaEventLog" editable="false" layoutX="15.0" layoutY="324.0" prefHeight="92.0" prefWidth="720.0" wrapText="true" />
            <Label layoutX="14.0" layoutY="73.0" text="Chat Messages" />
            <Label layoutX="14.0" layoutY="307.0" text="Event Log" />
            <ListView fx:id="listUsersConnected" layoutX="398.0" layoutY="90.0" prefHeight="190.0" prefWidth="334.0" />
            <Label layoutX="398.0" layoutY="73.0" text="Users Connected" />
            <Label layoutX="15.0" layoutY="430.0" text="nChat V1.0" textFill="#1ec31e">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <JFXButton fx:id="btnStartServer" layoutX="403.0" layoutY="11.0" onAction="#startServer" prefHeight="25.0" prefWidth="80.0" ripplerFill="GREEN" text="START">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></JFXButton>
            <JFXButton fx:id="btnStopServer" layoutX="532.0" layoutY="11.0" onAction="#stopServer" prefHeight="25.0" prefWidth="67.0" ripplerFill="RED" text="STOP">
               <font>
                  <Font name="Arial Bold" size="12.0" />
               </font></JFXButton>
            <JFXTextField fx:id="txtPorts" alignment="CENTER" layoutX="130.0" layoutY="11.0" onAction="#get" prefHeight="25.0" prefWidth="102.0" promptText="Submit,Press &gt;&gt;&gt;&gt;">
               <tooltip>
                  <Tooltip text="Some Of The Computer Keeps On Changing The Dedicated Ports" />
               </tooltip>
               <font>
                  <Font name="Berlin Sans FB" size="12.0" />
               </font>
            </JFXTextField>
            <Text layoutX="15.0" layoutY="28.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Enter the Free Port:" />
            <JFXButton buttonType="RAISED" layoutX="268.0" layoutY="11.0" onAction="#get" prefHeight="25.0" prefWidth="80.0" ripplerFill="YELLOW" text="Submit Port" />
            <JFXButton buttonType="RAISED" layoutX="664.0" layoutY="426.0" onAction="#exit" prefHeight="25.0" prefWidth="62.0" styleClass="offButton" stylesheets="@application.css" text="BACK" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </JFXButton>
      </children>
    </AnchorPane>
  </children>
  <stylesheets>
    <URL value="@css/BasicApplication.css" />
  </stylesheets>
</VBox>
